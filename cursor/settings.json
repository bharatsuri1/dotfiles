{
  "[cucumber]": {
    "editor.defaultFormatter": "CucumberOpen.cucumber-official"
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[markdown]": {
    "editor.codeActionsOnSave": {}
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[starlark]": {
    "editor.defaultFormatter": "BazelBuild.vscode-bazel"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "claudeCode.initialPermissionMode": "acceptEdits",
  "claudeCode.preferredLocation": "panel",
  "claudeCode.useCtrlEnterToSend": true,
  "claudeCode.useTerminal": false,
  "codesnap.showWindowControls": false,
  "cursor.composer.queueMessageDefaultBehavior": "queue",
  "cursor.composer.usageSummaryDisplay": "always",
  "cursor.cpp.disabledLanguages": ["plaintext"],
  "cursor.general.fontSmoothingAntialiased": true,
  "debug.confirmOnExit": "never",
  "debug.terminal.clearBeforeReusing": true,
  "debug.toolBarLocation": "floating",
  "docker.extension.enableComposeLanguageServer": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "block",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 14,
  "editor.formatOnSave": false,
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": true,
  "editor.padding.top": 8,
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "trailing",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/tmp/**": true
  },
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "gitlens.blame.avatars": true,
  "gitlens.currentLine.enabled": false,
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.plusFeatures.enabled": false,
  "gitlens.telemetry.enabled": false,
  "js/ts.experimental.useTsgo": true,
  "prettier.trailingComma": "none",
  "makefile.configureOnOpen": true,
  "remote.SSH.configFile": "~/.ssh/config",
  "remote.SSH.connectTimeout": 60,
  "remote.SSH.defaultExtensions": [
    "dbaeumer.vscode-eslint",
    "eamodio.gitlens",
    "editorconfig.editorconfig",
    "esbenp.prettier-vscode",
    "github.vscode-pull-request-github",
    "naumovs.color-highlight",
    "typescriptteam.native-preview",
    "yoavbls.pretty-ts-errors"
  ],
  "remote.SSH.enableAgentForwarding": false,
  "remote.SSH.enableDynamicForwarding": true,
  "remote.SSH.enableRemoteCommand": false,
  "remote.SSH.enableX11Forwarding": true,
  "remote.SSH.localServerDownload": "auto",
  "remote.SSH.lockfilesInTmp": false,
  "remote.SSH.logLevel": "debug",
  "remote.SSH.maxReconnectionAttempts": 2,
  "remote.SSH.remotePlatform": {
    "*": "linux"
  },
  "remote.SSH.remoteServerListenOnSocket": true,
  "remote.SSH.showLoginTerminal": false,
  "remote.SSH.useExecServer": false,
  "remote.SSH.useFlock": true,
  "remote.SSH.useLocalServer": false,
  "search.collapseResults": "alwaysExpand",
  "search.defaultViewMode": "tree",
  "search.exclude": {
    "**/node_modules/**": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/tmp/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true
  },
  "svelte.enable-ts-plugin": true,
  "terminal.external.osxExec": "/Applications/Ghostty.app",
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.confirmOnExit": "never",
  "terminal.integrated.confirmOnKill": "never",
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.defaultLocation": "view",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "icon": "zap",
      "path": "zsh",
      "args": ["-l"]
    }
  },
  "terminal.integrated.scrollback": 2000,
  "update.mode": "default",

  // ╔══════════════════════════════════════════╗
  // ║           VIM CONFIGURATION              ║
  // ╚══════════════════════════════════════════╝

  "vim.easymotion": true,
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.leader": "<space>",
  "vim.smartRelativeLine": true,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.insert": "block-outline",
  "vim.whichwrap": "b,s,h,l",
  "vim.enableNeovim": true,
  "vim.camelCaseMotion.enable": true,

  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-c>": false,
    "<C-v>": false,
    "<C-x>": false,
    "<C-z>": false,
    "<C-p>": false
  },

  // --- Insert Mode ---
  "vim.insertModeKeyBindings": [
    { "before": ["j", "j"], "after": ["<Esc>"] },
    { "before": ["j", "k"], "after": ["<Esc>"] }
  ],

  // --- Normal Mode ---
  "vim.normalModeKeyBindingsNonRecursive": [
    // Clear search highlight
    { "before": ["<Esc>"], "commands": [":nohl"] },

    // Scroll + center screen
    { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },
    { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },

    // Search next/prev + center + open folds
    { "before": ["n"], "after": ["n", "z", "z", "z", "v"] },
    { "before": ["N"], "after": ["N", "z", "z", "z", "v"] },

    // Join lines without moving cursor
    { "before": ["J"], "after": ["m", "z", "J", "`", "z"] },

    // Window navigation (Ctrl+hjkl)
    { "before": ["<C-h>"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": ["<C-j>"], "commands": ["workbench.action.focusBelowGroup"] },
    { "before": ["<C-k>"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": ["<C-l>"], "commands": ["workbench.action.focusRightGroup"] },

    // Tab cycling
    { "before": ["<Tab>"], "commands": ["workbench.action.nextEditor"] },
    { "before": ["<S-Tab>"], "commands": ["workbench.action.previousEditor"] },

    // Jump to tab by number
    { "before": ["<leader>", "1"], "commands": ["workbench.action.openEditorAtIndex1"] },
    { "before": ["<leader>", "2"], "commands": ["workbench.action.openEditorAtIndex2"] },
    { "before": ["<leader>", "3"], "commands": ["workbench.action.openEditorAtIndex3"] },
    { "before": ["<leader>", "4"], "commands": ["workbench.action.openEditorAtIndex4"] },
    { "before": ["<leader>", "5"], "commands": ["workbench.action.openEditorAtIndex5"] },

    // Splits
    { "before": ["<leader>", "s"], "commands": ["workbench.action.splitEditorDown"] },
    { "before": ["<leader>", "v"], "commands": ["workbench.action.splitEditorRight"] },

    // Close buffer/split
    { "before": ["<leader>", "x"], "commands": ["workbench.action.closeActiveEditor"] },
    { "before": ["<leader>", "q"], "commands": ["workbench.action.closeEditorsInGroup"] },

    // File explorer toggle
    { "before": ["<leader>", "e"], "commands": ["workbench.action.toggleSidebarVisibility"] },

    // Find / Search
    { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "f", "w"], "commands": ["editor.action.addSelectionToNextFindMatch"] },
    { "before": ["<leader>", "f", "s"], "commands": ["workbench.action.gotoSymbol"] },
    { "before": ["<leader>", "f", "S"], "commands": ["workbench.action.showAllSymbols"] },

    // Code actions
    { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"] },
    { "before": ["<leader>", "c", "r"], "commands": ["editor.action.rename"] },
    { "before": ["<leader>", "c", "f"], "commands": ["editor.action.formatDocument"] },

    // LSP / Go to
    { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
    { "before": ["g", "r"], "commands": ["references-view.findReferences"] },
    { "before": ["g", "i"], "commands": ["references-view.findImplementations"] },
    { "before": ["g", "t"], "commands": ["references-view.findTypeDefinition"] },

    // Diagnostics
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
    { "before": ["<leader>", "d"], "commands": ["workbench.actions.view.problems"] },

    // Hover info
    { "before": ["K"], "commands": ["editor.action.showHover"] },

    // Terminal toggle
    { "before": ["<leader>", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] },

    // Git
    { "before": ["<leader>", "g", "g"], "commands": ["workbench.view.scm"] },
    { "before": ["<leader>", "g", "b"], "commands": ["gitlens.toggleFileBlame"] },

    // Indent (stay in normal mode)
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },

    // Move lines
    { "before": ["<A-j>"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["<A-k>"], "commands": ["editor.action.moveLinesUpAction"] },

    // Command palette
    { "before": ["<leader>", "p"], "commands": ["workbench.action.showCommands"] }
  ],

  // --- Visual Mode ---
  "vim.visualModeKeyBindingsNonRecursive": [
    // Indent and stay in visual
    { "before": [">"], "commands": ["editor.action.indentLines"], "after": ["g", "v"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"], "after": ["g", "v"] },

    // Move lines
    { "before": ["<A-j>"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["<A-k>"], "commands": ["editor.action.moveLinesUpAction"] },

    // Paste without overwriting register
    { "before": ["p"], "after": ["p", "g", "v", "y"] }
  ],

  "window.commandCenter": true,
  "window.newWindowDimensions": "maximized",
  "window.restoreWindows": "none",
  "breadcrumbs.enabled": true,
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "Rosé Pine",
  "workbench.editor.autoLockGroups": {},
  "workbench.editor.enablePreview": false,
  "workbench.editor.revealIfOpen": true,
  "workbench.list.smoothScrolling": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "none",
  "terminal.integrated.smoothScrolling": true,
  "window.autoDetectColorScheme": false,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "editor.accessibilitySupport": "on"
}
