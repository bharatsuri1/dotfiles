{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "app": {
    "appearance": "dark",
    "preferredEditor": "code",
    "minimalMode": true,
    "sendAnonymousTelemetry": false,
    "confirmQuit": "dirty-only",
    "reorderOnNotification": false,
    "keepWorkspaceOpenWhenClosingLastSurface": true,
    "workspaceInheritWorkingDirectory": true,
    "commandPaletteSearchesAllSurfaces": true
  },

  "terminal": {
    "showScrollBar": false,
    "copyOnSelect": true,
    "autoResumeAgentSessions": false,
    "agentHibernation": {
      "enabled": false,
      "idleSeconds": 30,
      "maxLiveTerminals": 10
    },
    "textBoxMaxLines": 12
  },

  "sidebar": {
    "hideAllDetails": true,
    "wrapWorkspaceTitles": true,
    "showWorkspaceDescription": true,
    "showCustomMetadata": true,
    "showPullRequests": false,
    "showPorts": true,
    "showLog": true,
    "showProgress": true,
    "showNotificationMessage": true,
    "openPullRequestLinksInCmuxBrowser": false,
    "openPortLinksInCmuxBrowser": false,
    "showBranchDirectory": true,
    "branchLayout": "inline"
  },

  "sidebarAppearance": {
    "matchTerminalBackground": true
  },

  "notifications": {
    "unreadPaneRing": false,
    "paneFlash": false,
    "dockBadge": true,
    "showInMenuBar": true,
    "sound": "none"
  },

  "browser": {
    "defaultSearchEngine": "kagi",
    "openTerminalLinksInCmuxBrowser": false,
    "interceptTerminalOpenCommandInCmuxBrowser": false,
    "hostsToOpenInEmbeddedBrowser": ["localhost", "*.localhost", "127.0.0.1"]
  },

  "workspaceColors": {
    "indicatorStyle": "washRail",
    "selectionColor": "#26233a",
    "notificationBadgeColor": "#c4a7e7",
    "colors": {
      "focus": "#31748f",
      "build": "#9ccfd8",
      "review": "#c4a7e7",
      "ops": "#f6c177",
      "learn": "#ea9d34",
      "scratch": "#6e6a86"
    }
  },

  "automation": {
    "socketControlMode": "cmuxOnly",
    "suppressSubagentNotifications": true
  },

  "markdown": {
    "fontSize": 15,
    "fontFamily": "",
    "maxWidth": 980
  },

  "fileEditor": {
    "wordWrap": true
  }
}
