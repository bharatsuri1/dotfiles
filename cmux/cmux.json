{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "terminal": {
    "showScrollBar": false,
    "autoResumeAgentSessions": true
  },

  "sidebar": {
    "hideAllDetails": true,
    "showWorkspaceDescription": true,
    "showCustomMetadata": true,
    "showPullRequests": false,
    "showPorts": true,
    "showLog": true,
    "showProgress": true,
    "showNotificationMessage": true,
    "openPullRequestLinksInCmuxBrowser": false,
    "openPortLinksInCmuxBrowser": false,
    "showBranchDirectory": true,
    "branchLayout": "inline"
  },

  "sidebarAppearance": {
    "matchTerminalBackground": false
  },

  "notifications": {
    "unreadPaneRing": false,
    "paneFlash": false,
    "dockBadge": true,
    "showInMenuBar": true
  },

  "browser": {
    "openTerminalLinksInCmuxBrowser": false,
    "interceptTerminalOpenCommandInCmuxBrowser": false
  },

  "workspaceColors": {
    "colors": {
      "blocked":     "#eb6f92",
      "oncall":      "#b4637a",
      "heads-down":  "#31748f",
      "tend":        "#9ccfd8",
      "pr-reviews":  "#56949f",
      "random":      "#908caa",
      "automations": "#c4a7e7",
      "caffeinate":  "#f6c177",
      "design":      "#907aa9",
      "prototype":   "#d97757",
      "learning":    "#ea9d34",
      "scratch":     "#6e6a86"
    }
  }

