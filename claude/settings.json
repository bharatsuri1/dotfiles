{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Read(//tmp/**)",
      "Edit(//tmp/**)",
      "mcp__tools__list",
      "mcp__tools__call",
      "Bash(export:*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(npm run lint *)",
      "Bash(npm run check *)",
      "Bash(npm run test *)",
      "Bash(npm run build *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf / --no-preserve-root)",
      "Bash(rm -rf /?*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf --one-file-system /)",
      "Bash(dd if=*.{zero,urandom,random} of=/dev/sd?*)",
      "Bash(dd if=* of=/dev/nvme?n?)",
      "Bash(shred -v*n /dev/sd?*)",
      "Bash(wipefs -a /dev/sd?*)",
      "Bash(mkfs.* /dev/sd?*)",
      "Bash(fdisk:*)",
      "Bash(parted -s /dev/sd?* mklabel gpt)",
      "Bash(grub-install:*)",
      "Bash(efibootmgr:*)",
      "Bash(flashrom:*)",
      "Bash(bios-flash-utility:*)",
      "Bash(shutdown -h now)",
      "Bash(poweroff)",
      "Bash(halt)",
      "Bash(reboot -f)",
      "Bash(systemctl *(poweroff|reboot|halt|rescue|emergency))",
      "Bash(init 0)",
      "Bash(echo b > /proc/sysrq-trigger)",
      "Bash(kill -9 -1)",
      "Bash(pkill -9 -u:*)",
      "Bash(killall -9:*)",
      "Bash(:\\(\\){ :|:& };:)",
      "Bash(while true; do :; done &)",
      "Bash(chmod -R 0 /)",
      "Bash(chown -R 0:0 /)",
      "Bash(setfacl -Rb /)",
      "Bash(setenforce 0)",
      "Bash(umount -a)",
      "Bash(mount -o remount,ro /)",
      "Bash(mount --bind / /tmp/malicious)",
      "Bash(pivot_root:*)",
      "Bash(iptables -F)",
      "Bash(iptables -P (INPUT|FORWARD|OUTPUT) ACCEPT)",
      "Bash(ufw disable)",
      "Bash(firewalld --zone=public --remove-service=ssh)",
      "Bash(aa-teardown)",
      "Bash(sysctl -w kernel.randomize_va_space=0)",
      "Bash(sudo su:*)",
      "Bash(sudo -i)",
      "Bash(su - root)",
      "Bash(echo \"* ALL=(ALL) NOPASSWD:ALL\" >> /etc/sudoers)",
      "Bash(curl * | (sh|bash|zsh|dash))",
      "Bash(wget * -O- | (sh|bash|zsh|dash))",
      "Bash(python -c:*)",
      "Bash(perl -e:*)",
      "Bash(bash -c \"$(curl -fsSL *)\")",
      "Bash(pip install:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(sftp:*)",
      "Bash(ftp:*)",
      "Bash(tftp:*)",
      "Bash(tcpdump:*)",
      "Bash(wireshark:*)",
      "Bash(ettercap:*)",
      "Bash(arpspoof:*)",
      "Bash(hping3:*)",
      "Bash(nmap:*)",
      "Bash(airmon-ng start:*)",
      "Bash(aircrack-ng:*)",
      "Bash(modprobe -r:*)",
      "Bash(rmmod:*)",
      "Bash(insmod:*)",
      "Bash(echo 1 > /proc/sys/kernel/sysrq)",
      "Bash(echo \"c\" > /proc/sysrq-trigger)",
      "Bash(echo \"\" > /etc/{passwd,shadow,group,gshadow})",
      "Bash(cp /dev/null /etc/{passwd,shadow})",
      "Bash(crontab -e:*)",
      "Bash(crontab -r:*)",
      "Bash(useradd -u 0:*)",
      "Bash(docker run --privileged:*)",
      "Bash(docker run -v /:/mnt *)",
      "Bash(lxc config set:*)",
      "Bash(virsh destroy:*)",
      "Bash(virsh undefine:*)",
      "Bash(yes > /dev/null &)",
      "Bash(dd if=/dev/zero of=/dev/null &)",
      "Bash(stress --cpu 0 --io 0 --vm 0 --vm-bytes 100G --timeout 9999s)"
    ],
    "ask": [],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 2
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "stable"
}
